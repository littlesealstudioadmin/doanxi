---
import { site } from '../data/site';
const { promos } = site;
---

<aside class="promo" aria-label="특별 계약 혜택">
  <div class="promo__in container">
    <p class="promo__title"><strong>특별 계약 혜택</strong> 선착순 동·호 지정</p>
    <ul class="promo__list">
      {
        promos.map((p) => (
          <li>
            <span class="promo__label">{p.label}</span>
            <span class="promo__value">{p.value}</span>
            {p.note && <span class="promo__note">{p.note}</span>}
          </li>
        ))
      }
    </ul>
  </div>
</aside>

<style>
  .promo {
    background: linear-gradient(90deg, var(--navy), var(--navy-soft));
    color: #fff;
  }
  .promo__in {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 18px 28px;
    padding-block: 18px;
  }
  .promo__title {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    white-space: nowrap;
  }
  .promo__title strong {
    color: #e3c894;
    font-weight: 800;
    margin-right: 6px;
  }
  .promo__list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 12px;
    margin-left: auto;
  }
  .promo__list li {
    display: flex;
    align-items: baseline;
    gap: 7px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 10px;
    padding: 8px 13px;
  }
  .promo__label {
    font-size: 0.74rem;
    font-weight: 700;
    color: #e3c894;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .promo__value {
    font-size: 0.92rem;
    font-weight: 700;
  }
  .promo__note {
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.55);
  }
  @media (max-width: 700px) {
    .promo__list {
      margin-left: 0;
      width: 100%;
    }
    /* 좁은 칩에서 라벨이 세로로 쪼개지지 않게 내용을 세로 스택 */
    .promo__list li {
      flex: 1 1 calc(50% - 6px);
      flex-direction: column;
      align-items: flex-start;
      gap: 3px;
    }
  }
</style>
