---
import { site } from '../data/site';
const { agent } = site;
const telDigits = agent.phone.replace(/[^0-9+]/g, '');
---

<div class="fab" aria-label="빠른 상담">
  <a href={`tel:${telDigits}`} class="fab__call">☎ 전화상담</a>
  <a href="#contact" class="fab__reg">관심고객 등록</a>
</div>

<style>
  .fab {
    display: none;
  }
  @media (max-width: 820px) {
    .fab {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 60;
      display: grid;
      grid-template-columns: 1fr 1fr;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
    }
    .fab a {
      text-align: center;
      padding: 16px 8px;
      font-weight: 700;
      font-size: 0.98rem;
    }
    .fab__call {
      background: var(--navy);
      color: #fff;
    }
    .fab__reg {
      background: var(--accent);
      color: #fff;
    }
  }
</style>
