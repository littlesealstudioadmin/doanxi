---
import { site } from '../data/site';
const { agent } = site;
const telDigits = agent.phone.replace(/[^0-9+]/g, '');
---

<!-- 모바일 하단 고정 바 -->
<div class="fab" aria-label="빠른 상담">
  <a href={`tel:${telDigits}`} class="fab__call">☎ {agent.phone}</a>
  <a href="#contact" class="fab__reg">관심고객 등록</a>
</div>

<!-- 우측 하단 플로팅: 맨 위로 + 전화번호(스크롤 따라다님) -->
<div class="fab-side" aria-label="빠른 메뉴">
  <button type="button" class="fab-btn fab-top" id="fab-top" aria-label="맨 위로 이동" hidden>↑</button>
  <a href={`tel:${telDigits}`} class="fab-phone" aria-label={`전화상담 ${agent.phone}`}>
    <span class="fab-phone__ico" aria-hidden="true">☎</span>
    <span class="fab-phone__num">{agent.phone}</span>
  </a>
</div>

<style>
  .fab {
    display: none;
  }
  @media (max-width: 820px) {
    .fab {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 60;
      display: grid;
      grid-template-columns: 1fr 1fr;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
    }
    .fab a {
      text-align: center;
      padding: 16px 8px;
      font-weight: 700;
      font-size: 0.98rem;
    }
    .fab__call {
      background: var(--navy);
      color: #fff;
    }
    .fab__reg {
      background: var(--accent);
      color: #fff;
    }
  }

  /* 우측 하단 플로팅 (PC) */
  .fab-side {
    position: fixed;
    right: 16px;
    bottom: 24px;
    z-index: 61;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  /* 맨 위로 버튼(원형) */
  .fab-btn {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    cursor: pointer;
    border: 0;
    box-shadow: 0 6px 20px rgba(20, 33, 63, 0.28);
    transition: transform 0.15s ease, background 0.2s ease;
  }
  .fab-btn:active {
    transform: translateY(1px) scale(0.96);
  }
  .fab-top {
    background: #fff;
    color: var(--navy);
    border: 1px solid var(--line);
    font-size: 1.5rem;
    font-weight: 700;
  }
  .fab-top:hover {
    background: var(--bg-alt);
  }
  /* 전화번호 알약(스크롤 따라다님) */
  .fab-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 20px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-weight: 800;
    font-size: 1.08rem;
    letter-spacing: 0.02em;
    white-space: nowrap;
    text-decoration: none;
    box-shadow: 0 8px 26px rgba(20, 33, 63, 0.34);
    transition: transform 0.15s ease, background 0.2s ease;
  }
  .fab-phone:hover {
    background: var(--accent-dark);
  }
  .fab-phone:active {
    transform: translateY(1px) scale(0.98);
  }
  .fab-phone__ico {
    font-size: 1.12rem;
  }

  /* 모바일: 하단 고정 바가 전화 역할 → 알약은 숨기고 '맨 위로'만 노출 */
  @media (max-width: 820px) {
    .fab-side {
      bottom: 72px;
      right: 14px;
    }
    .fab-phone {
      display: none;
    }
  }
</style>

<script>
  const toTop = document.getElementById('fab-top');
  // 일정 이상 스크롤하면 '맨 위로' 버튼 노출
  const onScroll = () => {
    if (toTop) toTop.hidden = window.scrollY < 400;
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  toTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
