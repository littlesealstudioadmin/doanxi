---
import { site } from '../data/site';
const { agent } = site;
const telDigits = agent.phone.replace(/[^0-9+]/g, '');
---

<!-- 모바일 하단 고정 바 -->
<div class="fab" aria-label="빠른 상담">
  <a href={`tel:${telDigits}`} class="fab__call">☎ 전화상담</a>
  <a href="#contact" class="fab__reg">관심고객 등록</a>
</div>

<!-- 우측 하단 플로팅 버튼 (맨 위로 / 전화하기) -->
<div class="fab-side" aria-label="빠른 메뉴">
  <button type="button" class="fab-btn fab-top" id="fab-top" aria-label="맨 위로 이동" hidden>↑</button>
  <a href={`tel:${telDigits}`} class="fab-btn fab-call" aria-label="전화하기">☎</a>
</div>

<style>
  .fab {
    display: none;
  }
  @media (max-width: 820px) {
    .fab {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 60;
      display: grid;
      grid-template-columns: 1fr 1fr;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
    }
    .fab a {
      text-align: center;
      padding: 16px 8px;
      font-weight: 700;
      font-size: 0.98rem;
    }
    .fab__call {
      background: var(--navy);
      color: #fff;
    }
    .fab__reg {
      background: var(--accent);
      color: #fff;
    }
  }

  /* 우측 하단 플로팅 버튼 (PC·모바일 공통) */
  .fab-side {
    position: fixed;
    right: 16px;
    bottom: 24px;
    z-index: 61;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .fab-btn {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    border: 0;
    box-shadow: 0 6px 20px rgba(20, 33, 63, 0.28);
    transition: transform 0.15s ease, opacity 0.2s ease, background 0.2s ease;
    text-decoration: none;
  }
  .fab-btn:active {
    transform: translateY(1px) scale(0.96);
  }
  .fab-call {
    background: var(--accent);
    color: #fff;
  }
  .fab-call:hover {
    background: var(--accent-dark);
  }
  .fab-top {
    background: #fff;
    color: var(--navy);
    border: 1px solid var(--line);
    font-size: 1.5rem;
    font-weight: 700;
  }
  .fab-top:hover {
    background: var(--bg-alt);
  }
  /* 모바일에선 하단 고정 바 위로 띄움 */
  @media (max-width: 820px) {
    .fab-side {
      bottom: 72px;
      right: 14px;
    }
    .fab-btn {
      width: 46px;
      height: 46px;
    }
  }
</style>

<script>
  const toTop = document.getElementById('fab-top');
  // 일정 이상 스크롤하면 '맨 위로' 버튼 노출
  const onScroll = () => {
    if (toTop) toTop.hidden = window.scrollY < 400;
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  toTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
