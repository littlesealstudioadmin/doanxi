---
import { site } from '../data/site';
const { leadForm, agent } = site;
const telDigits = agent.phone.replace(/[^0-9+]/g, '');
---

<section class="section section--dark" id="contact">
  <div class="container">
    <div class="lead-wrap">
      <div class="lead-copy reveal">
        <h2>관심고객 등록 &amp; 방문 상담</h2>
        <p>
          분양가·동·호수·계약조건 등 상세한 안내는 <strong>{agent.name} {agent.title}</strong>가
          1:1로 상담해 드립니다. 편하게 연락 남겨주세요.
        </p>
        {leadForm.gift && <p class="lead-copy__gift"><span aria-hidden="true">🎁</span> {leadForm.gift}</p>}
        <div class="lead-copy__cta">
          <a href={`tel:${telDigits}`} class="btn btn--primary btn--lg">☎ {agent.phone}</a>
          {agent.kakaoUrl && <a href={agent.kakaoUrl} class="btn btn--ghost btn--lg" target="_blank" rel="noopener">카카오톡 상담</a>}
        </div>
        <p class="lead-copy__official">{agent.phoneOfficialLabel} {agent.phoneOfficial}</p>
      </div>

      <form class="lead-form reveal" id="leadForm" novalidate
        data-endpoint={leadForm.endpoint}
        data-phone={telDigits}>
        <div class="field">
          <label for="lf-name">성함</label>
          <input id="lf-name" name="name" type="text" required placeholder="홍길동" autocomplete="name" />
        </div>
        <div class="field">
          <label for="lf-phone">연락처</label>
          <input id="lf-phone" name="phone" type="tel" required placeholder="010-1234-5678" autocomplete="tel" inputmode="tel" />
        </div>
        {
          leadForm.askInterestType && (
            <div class="field">
              <label for="lf-type">관심 평형</label>
              <select id="lf-type" name="interest">
                <option value="">선택 안 함</option>
                <option>84㎡</option>
                <option>99㎡</option>
                <option>115㎡</option>
                <option>134㎡(펜트하우스)</option>
              </select>
            </div>
          )
        }
        <label class="consent">
          <input type="checkbox" name="agree" required />
          <span>개인정보 수집·이용에 동의합니다. <small>{leadForm.privacyNote}</small></span>
        </label>
        <button type="submit" class="btn btn--primary btn--lg lead-form__submit">상담 신청하기</button>
        <p class="lead-form__msg" id="lf-msg" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<style>
  .lead-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 5vw, 60px);
    align-items: center;
  }
  .lead-copy h2 {
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
  }
  .lead-copy p {
    margin-top: 14px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.02rem;
  }
  .lead-copy strong {
    color: #fff;
  }
  .lead-copy__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }
  .lead-copy__gift {
    margin-top: 18px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 16px;
    border: 1px solid rgba(227, 200, 148, 0.5);
    background: rgba(227, 200, 148, 0.12);
    border-radius: 10px;
    color: #f0dcb4;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .lead-copy__official {
    margin-top: 16px;
    font-size: 0.86rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .lead-form {
    background: #fff;
    border-radius: 18px;
    padding: clamp(24px, 4vw, 38px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
  }
  .field {
    margin-bottom: 16px;
  }
  .field label {
    display: block;
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 7px;
  }
  .field input,
  .field select {
    width: 100%;
    padding: 13px 15px;
    border: 1.5px solid var(--line);
    border-radius: 10px;
    font-size: 1rem;
    font-family: inherit;
    color: var(--ink);
    background: #fff;
    transition: border-color 0.15s;
  }
  .field input:focus,
  .field select:focus {
    outline: none;
    border-color: var(--accent);
  }
  .consent {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin: 6px 0 18px;
    font-size: 0.86rem;
    color: var(--ink-soft);
    cursor: pointer;
  }
  .consent input {
    margin-top: 3px;
    flex-shrink: 0;
  }
  .consent small {
    display: block;
    color: var(--muted);
    font-size: 0.76rem;
    margin-top: 2px;
  }
  .lead-form__submit {
    width: 100%;
  }
  .lead-form__msg {
    margin-top: 12px;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
    min-height: 1.2em;
  }
  .lead-form__msg.ok {
    color: #1c7c44;
  }
  .lead-form__msg.err {
    color: var(--danger);
  }
  @media (max-width: 820px) {
    .lead-wrap {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('leadForm') as HTMLFormElement | null;
  const msg = document.getElementById('lf-msg');
  function setMsg(text: string, kind: 'ok' | 'err') {
    if (!msg) return;
    msg.textContent = text;
    msg.className = 'lead-form__msg ' + kind;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = String(data.get('name') || '').trim();
    const phone = String(data.get('phone') || '').trim();
    if (!name || !phone) return setMsg('성함과 연락처를 입력해 주세요.', 'err');
    if (!data.get('agree')) return setMsg('개인정보 수집·이용에 동의해 주세요.', 'err');

    const endpoint = form.dataset.endpoint;
    const interest = String(data.get('interest') || '');

    if (endpoint) {
      try {
        setMsg('전송 중…', 'ok');
        if (endpoint.includes('script.google.com')) {
          // Google Apps Script: CORS 응답이 없어 no-cors로 전송(응답은 못 읽음 → 완료=성공으로 간주)
          await fetch(endpoint, {
            method: 'POST',
            mode: 'no-cors',
            body: new URLSearchParams({ name, phone, interest, agree: '동의' }),
          });
        } else {
          // 일반 폼 엔드포인트(Formspree 등)
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: data,
          });
          if (!res.ok) throw new Error('bad status');
        }
        form.reset();
        setMsg('상담 신청이 접수되었습니다. 곧 연락드리겠습니다. 감사합니다!', 'ok');
      } catch {
        setMsg('전송에 실패했습니다. 전화로 문의해 주세요.', 'err');
      }
    } else {
      // 엔드포인트 미설정 시: 문자(SMS)로 폴백 (모바일)
      const agentPhone = form.dataset.phone || '';
      const body = encodeURIComponent(
        `[도안자이 센텀리체 상담] 성함:${name} / 연락처:${phone}${interest ? ` / 관심:${interest}` : ''}`,
      );
      window.location.href = `sms:${agentPhone}?body=${body}`;
      setMsg('문자 앱으로 연결됩니다. 전송이 안 되면 전화로 문의해 주세요.', 'ok');
    }
  });
</script>
