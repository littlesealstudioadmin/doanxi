---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import { img } from '../lib/images';
const { overview } = site;
---

<section class="section" id="overview">
  <div class="container">
    <div class="sec-head reveal">
      <h2>{overview.title}</h2>
    </div>

    <div class="ov reveal">
      <div class="ov__media">
        <Image src={img(overview.image)} alt="도안자이 센텀리체 조감도" widths={[480, 800]} sizes="(max-width: 820px) 100vw, 50vw" />
      </div>
      <dl class="ov__table">
        {
          overview.rows.map(([k, v]) => (
            <div class="ov__row">
              <dt>{k}</dt>
              <dd>{v}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>

<style>
  .ov {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: start;
  }
  .ov__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    aspect-ratio: 4 / 3;
  }
  .ov__table {
    border-top: 2px solid var(--navy);
  }
  .ov__row {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 16px;
    padding: 15px 6px;
    border-bottom: 1px solid var(--line);
  }
  .ov__row dt {
    font-weight: 700;
    color: var(--navy);
    font-size: 0.95rem;
  }
  .ov__row dd {
    color: var(--ink-soft);
    font-size: 0.97rem;
  }
  @media (max-width: 820px) {
    .ov {
      grid-template-columns: 1fr;
    }
    .ov__row {
      grid-template-columns: 100px 1fr;
    }
  }
</style>
