---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import { img } from '../lib/images';
const { floorplans } = site;
---

<section class="section section--alt" id="floorplans">
  <div class="container">
    <div class="sec-head reveal">
      <h2>{floorplans.title}</h2>
      <p class="lead">{floorplans.lead}</p>
    </div>

    <div class="fp reveal">
      <button class="fp__nav fp__nav--prev" type="button" aria-label="이전 평면도">‹</button>

      <ul class="fp__track" id="fp-track">
        {
          floorplans.plans.map((p, i) => (
            <li class="fp__slide" data-i={i}>
              <button class="fp__btn" data-zoom={img(p.image).src} aria-label={`${p.name} 평면도 크게 보기`}>
                <span class="fp__imgwrap">
                  <Image
                    src={img(p.image)}
                    alt={`도안자이 센텀리체 ${p.name} 평면도`}
                    widths={[640, 900, 1200]}
                    sizes="(max-width: 760px) 86vw, 600px"
                  />
                  {p.tag && <span class="fp__tag">{p.tag}</span>}
                  <span class="fp__zoom">⤢ 크게 보기</span>
                </span>
                <span class="fp__meta">
                  <strong>{p.name}</strong>
                  <em>{p.area}</em>
                </span>
              </button>
            </li>
          ))
        }
      </ul>

      <button class="fp__nav fp__nav--next" type="button" aria-label="다음 평면도">›</button>
    </div>

    <div class="fp__dots" id="fp-dots">
      {
        floorplans.plans.map((p, i) => (
          <button class="fp__dot" type="button" data-i={i} aria-label={`${p.name} 보기`} />
        ))
      }
    </div>

    <p class="disclaimer">{floorplans.note}</p>
  </div>
</section>

<style>
  .fp {
    position: relative;
  }
  .fp__track {
    display: flex;
    gap: 18px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    /* 첫/마지막 슬라이드도 가운데 정렬되도록 좌우 여백 확보 */
    padding: 6px max(0px, calc((100% - 600px) / 2));
    scrollbar-width: none;
  }
  .fp__track::-webkit-scrollbar {
    display: none;
  }
  .fp__slide {
    flex: 0 0 min(600px, 86%);
    scroll-snap-align: center;
  }
  .fp__btn {
    display: block;
    width: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: #fff;
    cursor: zoom-in;
    padding: 0;
    text-align: left;
    box-shadow: var(--shadow);
  }
  .fp__imgwrap {
    position: relative;
    display: block;
    background: #fff;
  }
  .fp__imgwrap img {
    width: 100%;
    height: auto;
    display: block;
  }
  .fp__tag {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
    background: var(--accent);
    border-radius: 999px;
    padding: 5px 13px;
  }
  .fp__zoom {
    position: absolute;
    bottom: 12px;
    right: 12px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #fff;
    background: rgba(8, 12, 22, 0.62);
    border-radius: 999px;
    padding: 5px 12px;
    backdrop-filter: blur(3px);
  }
  .fp__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    padding: 15px 20px;
    border-top: 1px solid var(--line);
  }
  .fp__meta strong {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--navy);
  }
  .fp__meta em {
    font-style: normal;
    font-size: 0.9rem;
    color: var(--muted);
  }

  /* 좌우 네비게이션 */
  .fp__nav {
    position: absolute;
    top: 42%;
    transform: translateY(-50%);
    z-index: 3;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.95);
    box-shadow: var(--shadow);
    font-size: 1.6rem;
    line-height: 1;
    color: var(--navy);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, transform 0.15s;
  }
  .fp__nav:hover {
    background: #fff;
  }
  .fp__nav:active {
    transform: translateY(-50%) scale(0.94);
  }
  .fp__nav--prev {
    left: 4px;
  }
  .fp__nav--next {
    right: 4px;
  }
  .fp__nav[disabled] {
    opacity: 0.35;
    cursor: default;
  }

  /* 점 인디케이터 */
  .fp__dots {
    display: flex;
    justify-content: center;
    gap: 9px;
    margin-top: 22px;
  }
  .fp__dot {
    width: 9px;
    height: 9px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: #cfd3db;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
  }
  .fp__dot.is-on {
    background: var(--accent);
    transform: scale(1.3);
  }

  @media (max-width: 760px) {
    .fp__nav {
      width: 40px;
      height: 40px;
      font-size: 1.3rem;
    }
  }
</style>

<script>
  const track = document.getElementById('fp-track');
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.fp__slide'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.fp__dot'));
  const prev = document.querySelector<HTMLButtonElement>('.fp__nav--prev');
  const next = document.querySelector<HTMLButtonElement>('.fp__nav--next');

  if (track && slides.length) {
    // 트랙 중앙에 가장 가까운 슬라이드 인덱스
    const current = () => {
      const center = track.scrollLeft + track.clientWidth / 2;
      let best = 0;
      let bestDist = Infinity;
      slides.forEach((s, i) => {
        const c = s.offsetLeft + s.offsetWidth / 2;
        const d = Math.abs(c - center);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });
      return best;
    };

    const go = (i: number) => {
      const s = slides[i];
      if (!s) return;
      track.scrollTo({
        left: s.offsetLeft - (track.clientWidth - s.offsetWidth) / 2,
        behavior: 'smooth',
      });
    };

    const sync = () => {
      const i = current();
      dots.forEach((d, j) => d.classList.toggle('is-on', j === i));
      if (prev) prev.disabled = i === 0;
      if (next) next.disabled = i === slides.length - 1;
    };

    prev?.addEventListener('click', () => go(Math.max(0, current() - 1)));
    next?.addEventListener('click', () => go(Math.min(slides.length - 1, current() + 1)));
    dots.forEach((d, i) => d.addEventListener('click', () => go(i)));

    let raf = 0;
    track.addEventListener(
      'scroll',
      () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(sync);
      },
      { passive: true },
    );
    sync();
  }
  // 평면도 확대는 Base.astro의 공용 라이트박스(data-zoom)가 처리
</script>
