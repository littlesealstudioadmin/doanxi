---
import { site } from '../data/site';
import MediaFrame from './MediaFrame.astro';
const { design } = site;
---

<section class="section" id="design">
  <div class="container">
    <div class="sec-head reveal">
      <h2>{design.title}</h2>
      <p class="lead">{design.lead}</p>
    </div>

    <ul class="dsg__features reveal">
      {
        design.features.map((f) => (
          <li>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </li>
        ))
      }
    </ul>

    <div class="dsg__layouts reveal">
      {
        design.layouts.map((l) => (
          <MediaFrame
            src={l.image}
            alt={`도안자이 센텀리체 ${l.title}`}
            caption={`${l.title} — 참고용, 실제와 다를 수 있습니다.`}
            zoom={l.zoom}
            pad={l.pad}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .dsg__features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .dsg__features li {
    padding: 22px 24px;
    background: var(--bg-alt);
    border-radius: var(--radius);
    border-left: 3px solid var(--accent);
  }
  .dsg__features h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
  }
  .dsg__features p {
    margin-top: 6px;
    font-size: 0.92rem;
    color: var(--muted);
  }
  @media (max-width: 760px) {
    .dsg__features {
      grid-template-columns: 1fr;
    }
  }
</style>
