---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import { img } from '../lib/images';
const { hero, agent } = site;
const telHref = `tel:${agent.phone.replace(/[^0-9+]/g, '')}`;
---

<section class="hero" id="hero">
  <div class="hero__slides" aria-hidden="true">
    {
      hero.slides.map((src, i) => (
        <Image
          src={img(src)}
          alt=""
          class={`hero__img${i === 0 ? ' is-active' : ''}`}
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
        />
      ))
    }
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__body container">
    <h1 class="hero__title">
      {hero.headline.map((line) => <span>{line}</span>)}
    </h1>
    <p class="hero__sub">{hero.subcopy}</p>

    <ul class="hero__badges">
      {hero.badges.map((b) => <li>{b}</li>)}
    </ul>

    <div class="hero__cta">
      <a href="#contact" class="btn btn--primary btn--lg">관심고객 등록 / 상담신청</a>
      <a href={telHref} class="btn btn--ghost btn--lg">☎ 전화상담</a>
    </div>
  </div>

  <a href="#overview" class="hero__scroll" aria-label="아래로 스크롤">
    <span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(92vh, 860px);
    display: flex;
    align-items: center;
    color: #fff;
    overflow: hidden;
  }
  .hero__slides {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.1s ease;
  }
  .hero__img.is-active {
    opacity: 1;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    /* 상단 어둡게(이미지에 박힌 네이비 문구를 어둠에 묻음) + 좌측 강하게(헤드라인 가독성) */
    background:
      linear-gradient(
        180deg,
        rgba(10, 16, 30, 0.82) 0%,
        rgba(10, 16, 30, 0.6) 34%,
        rgba(10, 16, 30, 0.16) 58%,
        rgba(10, 16, 30, 0) 82%
      ),
      linear-gradient(
        90deg,
        rgba(10, 16, 30, 0.82) 0%,
        rgba(10, 16, 30, 0.46) 55%,
        rgba(10, 16, 30, 0.26) 100%
      );
  }
  /* 모바일: cover가 좌우를 크게 잘라내므로 보이는 영역을 우측(빌딩)으로 옮겨
     중앙에 박힌 문구를 화면 밖으로 밀어냄 + 전체적으로 살짝 더 어둡게 */
  @media (max-width: 760px) {
    .hero__img {
      object-position: 92% center;
    }
    .hero__scrim {
      background:
        linear-gradient(
          180deg,
          rgba(10, 16, 30, 0.78) 0%,
          rgba(10, 16, 30, 0.5) 55%,
          rgba(10, 16, 30, 0.32) 100%
        ),
        linear-gradient(
          90deg,
          rgba(10, 16, 30, 0.55) 0%,
          rgba(10, 16, 30, 0) 32%
        );
    }
  }
  .hero__body {
    position: relative;
    z-index: 1;
    width: 100%;
  }
  .hero__title {
    font-size: clamp(2.1rem, 6.6vw, 4.2rem);
    font-weight: 800;
    line-height: 1.16;
    letter-spacing: -0.035em;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.3);
  }
  .hero__title span {
    display: block;
  }
  .hero__sub {
    margin-top: 18px;
    font-size: clamp(1rem, 2.6vw, 1.3rem);
    color: rgba(255, 255, 255, 0.92);
    font-weight: 500;
  }
  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 26px;
  }
  .hero__badges li {
    font-size: 0.85rem;
    font-weight: 600;
    padding: 7px 14px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(4px);
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 36px;
  }
  .hero__scroll {
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    width: 26px;
    height: 42px;
    border: 2px solid rgba(255, 255, 255, 0.6);
    border-radius: 14px;
  }
  .hero__scroll span {
    position: absolute;
    top: 8px;
    left: 50%;
    width: 4px;
    height: 8px;
    margin-left: -2px;
    background: #fff;
    border-radius: 2px;
    animation: hscroll 1.6s ease-in-out infinite;
  }
  @keyframes hscroll {
    0% { opacity: 0; transform: translateY(0); }
    40% { opacity: 1; }
    80% { opacity: 0; transform: translateY(12px); }
    100% { opacity: 0; }
  }
  @media (max-width: 600px) {
    .hero__scroll { display: none; }
  }
</style>

<script>
  // 히어로 캐러셀 (단순 페이드)
  const imgs = Array.from(document.querySelectorAll('.hero__img'));
  if (imgs.length > 1) {
    let i = 0;
    setInterval(() => {
      imgs[i].classList.remove('is-active');
      i = (i + 1) % imgs.length;
      imgs[i].classList.add('is-active');
    }, 5000);
  }
</script>
